# OpenAI API key — pay-as-you-go account
# https://platform.openai.com/api-keys
# Используется тремя узлами: чат-модель (gpt-4o-mini), распознавание голоса
# (Whisper) и эмбеддинги базы знаний (text-embedding-3-small).
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY

# Telegram bot token — получить у @BotFather командой /newbot
# Подставляется в credential Telegram на узлах бота.
TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN

# Telegram chat id менеджера — кому уходит сводка по горячему лиду.
# Узнать свой id: напишите @userinfobot. Подставляется в ноду «Уведомить менеджера».
# ВАЖНО: менеджер должен хотя бы раз написать боту, иначе Telegram не доставит сводку
# (бот не может написать пользователю первым).
MANAGER_CHAT_ID=REPLACE_WITH_MANAGER_CHAT_ID
