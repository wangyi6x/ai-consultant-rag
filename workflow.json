      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "text": "={{ $(\"Разобрать ответ и лид\").item.json.clientText }}",
        "additionalFields": {
          "appendAttribution": false
        }
      }
    },
    {
      "id": "11a39a48-0c1c-4a51-b71c-0cb96074a3ba",
      "name": "Ответ клиенту",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        2460,
        440
      ],
