        }
      }
    },
    {
      "id": "53b24e53-35f4-4155-a29c-68f185f80b35",
      "name": "Sticky Note 83d9b7a6",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        190,
        250
      ],
      "parameters": {
        "content": "## DelAI AI продавец-квалификатор\nTelegram-бот ваш Telegram-бот. RAG по базе знаний delai_kb (общий стор с WF DelAI KB ingestion). Голос распознаётся через Whisper. Горячий лид с контактом уходит менеджеру в личку, служебный тег [[LEAD|hot|...]] вырезается из ответа клиенту.",
        "color": 5,
        "width": 2300,
        "height": 220
      }
    }
