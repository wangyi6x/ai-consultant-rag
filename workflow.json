    {
      "id": "75f8547e-90e1-4d94-a28c-fca21ec417ff",
      "name": "ИИ-продавец-квалификатор",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1800,
        320
      ],
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.userText }}",
        "options": {
          "systemMessage": "Ты - консультант-продавец агентства DelAI (автоматизация бизнеса на n8n и ИИ). Отвечай ТОЛЬКО на основе базы знаний - всегда вызывай инструмент \"Поиск по базе знаний DelAI\" перед ответом. Если в базе нет ответа - задай уточняющий вопрос, ничего не выдумывай. Веди живой диалог, выясни задачу клиента и его нишу, мягко квалифицируй лида: горячий - готов обсуждать внедрение или оставил контакт; тёплый - интересуется, но пока думает; холодный - просто смотрит. Цены не называй конкретными суммами - говори, что считаем индивидуально после короткого созвона или переписки. Когда лид ГОРЯЧИЙ И у тебя есть его контакт (телефон, email или @username), добавь В САМЫЙ КОНЕЦ ответа служебную строку строго в формате [[LEAD|hot|<ниша>|<задача>|<контакт>]] - это техническая метка для передачи менеджеру, она не должна выглядеть как часть сообщения клиенту. Если лид не горячий или контакта нет - метку не добавляй. Пиши по-русски, дружелюбно и по делу."
        }
      }
    },
    {
      "id": "03a2c230-0399-4275-870d-60d4b2b71cd2",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
        1620,
        520
      ],
      "parameters": {
        "model": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-4o-mini",
          "cachedResultName": "gpt-4o-mini"
        },
        "options": {
          "temperature": 0.3
        }
      }
    },
    {
      "id": "48b0ac92-e16f-49fe-bcf2-9a4e942dad66",
      "name": "Память диалога",
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1.4,
      "position": [
        1800,
        520
      ],
      "parameters": {
        "sessionIdType": "customKey",
        "sessionKey": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "contextWindowLength": 10
      }
    },
    {
      "id": "6b6ce872-49dd-4600-a959-37378c4cdd07",
      "name": "Поиск по базе знаний DelAI",
      "type": "@n8n/n8n-nodes-langchain.vectorStoreInMemory",
      "typeVersion": 1.3,
      "position": [
        1980,
        520
      ],
      "parameters": {
        "mode": "retrieve-as-tool",
        "toolDescription": "База знаний агентства DelAI: услуги по направлениям (продажи, маркетинг, e-commerce, документы, HR, чат-боты), как работаем, цены. Используй для ответа на любой вопрос клиента об услугах, процессе и стоимости.",
        "memoryKey": {
          "__rl": true,
          "mode": "id",
          "value": "delai_kb"
        },
        "topK": 4,
        "includeDocumentMetadata": true
      }
    },
    {
      "id": "1072ea49-9b60-4dac-a4fd-1f01ce7061af",
      "name": "OpenAI Embeddings (поиск)",
      "type": "@n8n/n8n-nodes-langchain.embeddingsOpenAi",
      "typeVersion": 1.2,
      "position": [
        2160,
        520
      ],
      "parameters": {
        "model": "text-embedding-3-small"
      }
    },
    {
      "id": "16971cd4-80a3-428b-b308-872930b22e72",
      "name": "Разобрать ответ и лид",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2020,
        320
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $json.output || \"\";\nconst m = raw.match(/\\[\\[LEAD\\|hot\\|([^|]*)\\|([^|]*)\\|([^\\]]*)\\]\\]/);\nconst isHot = !!m;\nconst clean = raw.replace(/\\[\\[LEAD\\|hot\\|[^\\]]*\\]\\]/g, \"\").trim();\nreturn {\n  json: {\n    chatId: $json.chatId,\n    clientText: clean,\n    isHotLead: isHot,\n    leadNiche: isHot ? (m[1] || \"\").trim() : \"\",\n    leadTask: isHot ? (m[2] || \"\").trim() : \"\",\n    leadContact: isHot ? (m[3] || \"\").trim() : \"\"\n  }\n};"
      }
    },
    {
      "id": "07d5f3ed-3bf8-4561-bf78-034032a18722",
      "name": "Горячий лид?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        2240,
        320
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.isHotLead }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "6203f27c-3ef7-4dce-a229-6396f36c735c",
      "name": "Уведомить менеджера",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        2460,
        200
      ],
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "REPLACE_WITH_MANAGER_CHAT_ID",
        "text": "=🔥 Горячий лид DelAI\nНиша: {{ $json.leadNiche }}\nЗадача: {{ $json.leadTask }}\nКонтакт: {{ $json.leadContact }}\nChat ID клиента: {{ $json.chatId }}",
        "additionalFields": {
          "appendAttribution": false
        }
      }
    },
    {
      "id": "b985bcd1-d4b6-46d4-8e2e-e47fd443538d",
      "name": "Ответ клиенту (горячий)",
      "type": "n8n-nodes-base.telegram",
